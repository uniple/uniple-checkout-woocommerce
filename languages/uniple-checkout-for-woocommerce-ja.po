msgid "uniple checkout (JPYC)"
msgstr "uniple チェックアウト（JPYC）"

msgid "JPYC stablecoin hosted checkout, powered by uniple. Redirects to uniple checkout page."
msgstr "uniple が提供する JPYC 日本円ステーブルコインのホスト型チェックアウトです。uniple のチェックアウトページへリダイレクトします。"

msgid "Pay with JPYC via uniple hosted checkout."
msgstr "uniple のホスト型チェックアウトで JPYC をお支払いください。"

msgid "Enable / Disable"
msgstr "有効化 / 無効化"

msgid "Enable uniple checkout (JPYC)"
msgstr "uniple チェックアウト（JPYC）を有効化"

msgid "Title"
msgstr "タイトル"

msgid "Description"
msgstr "説明"

msgid "API base URL"
msgstr "API ベース URL"

msgid "Mode"
msgstr "モード"

msgid "Live"
msgstr "本番"

msgid "Test"
msgstr "テスト"

msgid "Merchant label"
msgstr "加盟店ラベル"

msgid "API key"
msgstr "API キー"

msgid "Issued by uniple admin. Stored masked; re-enter to update."
msgstr "uniple 管理者から発行されます。保存後はマスク表示されるため、更新する場合は再入力してください。"

msgid "Webhook secret"
msgstr "Webhook シークレット"

msgid "HMAC-SHA256 webhook signing secret. Stored masked; re-enter to update."
msgstr "HMAC-SHA256 の Webhook 署名シークレットです。保存後はマスク表示されるため、更新する場合は再入力してください。"

#. translators: %s: merchant application form URL
msgid "uniple checkout requires a merchant account. <a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">Apply for an account</a> and uniple will issue your API key and webhook secret."
msgstr "uniple チェックアウトのご利用には加盟店アカウントが必要です。<a href=\"%s\" target=\"_blank\" rel=\"noopener noreferrer\">加盟店申請（https://forms.gle/b8kwVZeynA1ffV8j6）</a>を行うと、uniple から API キーと Webhook シークレットが発行されます。"

msgid "Insufficient permission."
msgstr "権限が不足しています。"

msgid "Order not found."
msgstr "注文が見つかりません。"

msgid "Order amount must be an integer JPYC value."
msgstr "注文金額は整数の JPYC 値である必要があります。"

msgid "Payment gateway is temporarily unavailable. Please try again."
msgstr "この決済方法は一時的に利用できません。しばらくしてからもう一度お試しください。"

#. translators: %s: order number
msgid "WooCommerce order #%s"
msgstr "WooCommerce 注文 #%s"

msgid "uniple checkout session created."
msgstr "uniple チェックアウトセッションを作成しました。"

#. translators: 1: session id, 2: tx hash
msgid "uniple checkout completed (session=%1$s, tx=%2$s)."
msgstr "uniple チェックアウトが完了しました（session=%1$s, tx=%2$s）。"

#. translators: %s: session id
msgid "uniple checkout completed via option C live lookup (session=%s)."
msgstr "option C のライブ照会により uniple チェックアウトが完了しました（session=%s）。"
